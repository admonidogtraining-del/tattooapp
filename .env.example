# Copy this file to .env and fill in your keys.
# Only VITE_GEMINI_API_KEY is required. The others extend the fallback chain.

# Required — Google Gemini + Imagen 4
# Get at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional — adds FLUX.2-dev as a free fallback after Imagen quota is exhausted.
# 1. Create a free account at https://huggingface.co
# 2. Get a token at https://huggingface.co/settings/tokens (Read access)
# 3. Accept the model license at https://huggingface.co/black-forest-labs/FLUX.2-dev
VITE_HF_API_KEY=your_huggingface_token_here
